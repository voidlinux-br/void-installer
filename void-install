sh_checkroot() {
	if [ "$(id -u)" != "0" ]; then
		die "${red} ${cmsg_operRoot[$LC_DEFAULT]}"
	fi
}

sh_checknet() {
   xurl="$1"
   # have internet?
	last_msg="${cmsg_ChecandoRota[$LC_DEFAULT]} ${xurl}"
	msg "INFO" "$last_msg" "$(log_info_msg $last_msg)"
	response=$(curl --compressed -s -w "%{http_code}\n" -o /dev/null -k --url "${xurl}")
	if [ "$response" -eq 000 ] && [ "$response" -eq 404 ]
	then
		evaluate_retval "1"
		die "${cmsg_SemRota[$LC_DEFAULT]} ($xurl) - ${cmsg_CheckNet[$LC_DEFAULT]}"
   fi
   evaluate_retval "$?"
   return $?
}

sh_downloadtarball() {
	last_msg="${cmsg_IniciandoDownload[$LC_DEFAULT]} $url_tarball/live/current/$_TARBALL_ROOTFS"
	msg "INFO" "$last_msg" "$(log_info_msg $last_msg)"
	#curl --insecure --silent --remote-name "$url_tarball/live/current/$_TARBALL_ROOTFS" >>"$BOOTLOG" 2>&1 ||
	curl -L -C - --insecure --silent --remote-name "$url_tarball/$_TARBALL_ROOTFS" 2>&1 | tee -i -a "$BOOTLOG" >$LOGGER
	if [[ "${PIPESTATUS[0]}" -eq 1 ]]; then
		evaluate_retval "1"
		die "${cmsg_SemRota[$LC_DEFAULT]} ($url_mirror) - ${cmsg_CheckNet[$LC_DEFAULT]}"
		return 1
	fi
	evaluate_retval "0"
	return 0
}

sh_checktarball() {
	last_msg="${cmsg_ChecandoTarball[$LC_DEFAULT]} rootfs $_TARBALL_ROOTFS"
	msg "INFO" "$last_msg" "$(log_info_msg $last_msg)"
	tar -tf "$_TARBALL_ROOTFS" 2>&1 | tee -i -a "$BOOTLOG" >$LOGGER
	if [[ "${PIPESTATUS[0]}" -eq 1 ]]; then
	   evaluate_retval "1" "$err_not_fatal"
		rm -f void-x86_64-base-minimal-current.tar.xz
		sh_downloadtarball
	else
	   evaluate_retval "0"
		return 0
	fi
	return "${PIPESTATUS[0]}"
}

sh_checkDependencies() {
	local d
	local errorFound=0
	declare -a missing

	for d in "${DEPENDENCIES[@]}"; do
		[[ -z $(command -v "$d") ]] && missing+=("$d") && errorFound=1 && printf '%s\n' "${red}${cmsg_ERRO[$LC_DEFAULT]}${reset}: ${cmsg_CommandNotFound[$LC_DEFAULT]} ${cyan}'$d'${reset}"
	done
	if (( errorFound )); then
		echo "${yellow}--------------${cmsg_ImpossivelContinuar[$LC_DEFAULT]}-------------${reset}"
		echo "${cmsg_ImpossivelContinuar1[$LC_DEFAULT]}" >&2
		echo "${cmsg_ImpossivelContinuar2[$LC_DEFAULT]} \$PATH" >&2
		echo "${yellow}-----------------------------------------------${reset}"

		if [[ "$distro" = 'void' ]] ; then
			echo
			if readconf "${yellow}${cmsg_InstCommand[$LC_DEFAULT]} '${cyan}${missing[*]}${reset}'?"; then
				if xbps-install -S "${missing[*]}"; then
					die "${cmsg_RunNew[$LC_DEFAULT]}"
				else
					die "${cmsg_RunNewErro[$LC_DEFAULT]}"
				fi
			fi
		fi
		die "${cmsg_ERRO[$LC_DEFAULT]}: ${cmsg_InstalacaoAbortada[$LC_DEFAULT]}..."
	fi
}

