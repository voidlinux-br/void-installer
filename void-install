	while true
	do
		sh_touchconf
		if [ -z "$DEFITEM" ]; then
			DEFITEM="${cmsg_Mirror[$LC_DEFAULT]}"
		fi

		menu=$(${DIALOG}																		\
			--backtitle "$ccabec"															\
		   --erase-on-exit 																	\
			--colors																				\
			--default-item "$DEFITEM"														\
