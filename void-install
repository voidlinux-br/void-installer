			--title "$APP - ${cmsg_MenuInstalacao[$LC_DEFAULT]}"					\
			--menu "${cmsg_LABEL[$LC_DEFAULT]}" 9 100 0								\
			"${cmsg_Mirror[$LC_DEFAULT]}"		"${cmsg_descMirror[$LC_DEFAULT]}"					\
			"${cmsg_Disco[$LC_DEFAULT]}"		"${cmsg_descDisco[$LC_DEFAULT]}"						\
			"FileSystem"							"${cmsg_descFileSystem[$LC_DEFAULT]}"				\
			"BootLoader"							"${cmsg_descBootLoader[$LC_DEFAULT]}"				\
			"${cmsg_Teclado[$LC_DEFAULT]}"	"${cmsg_descTeclado[$LC_DEFAULT]}"					\
			"Timezone" 								"${cmsg_descTimezone[$LC_DEFAULT]}"					\
			"Wm" 										"${cmsg_descWm[$LC_DEFAULT]}"							\
			"Wifi" 									"${cmsg_descWifi[$LC_DEFAULT]}"						\
			"Extra"									"${cmsg_descExtra[$LC_DEFAULT]}"						\
			"${cmsg_Instalar[$LC_DEFAULT]}"	"${cmsg_descInstalar[$LC_DEFAULT]}"					\
			"Services"								"Util void-services (opcional)"			   		\
			"${cmsg_Sair[$LC_DEFAULT]}"		"${cmsg_descSair[$LC_DEFAULT]}" 2>&1 >/dev/tty 	)

		if [ $? -eq 3 ]; then
			display_config
			info "${cmsg_ConfSalva[LC_DEFAULT]}" "$SETUP"
			continue
		fi

		case "$menu" in
        	"${cmsg_Mirror[$LC_DEFAULT]}")	sh_choosemirror "$@" && [ -n "$LMIRROR" ]		&& DEFITEM="${cmsg_Disco[$LC_DEFAULT]}";;
			"${cmsg_Disco[$LC_DEFAULT]}")		sh_choosedisk        && [ -n "$LDISCO" ]		&& DEFITEM="FileSystem";;
			"FileSystem")							sh_choosefilesystem  && [ -n "$LFS" ]			&& DEFITEM="BootLoader";;
			"BootLoader")							sh_choosegrub        && [ -n "$LGRUB" ]		&& DEFITEM="${cmsg_Teclado[$LC_DEFAULT]}";;
        	"${cmsg_Teclado[$LC_DEFAULT]}")	sh_choosekeymap      && [ -n "$LTECLADO" ]	&& DEFITEM="Timezone";;
        	"Timezone") 							sh_choosetimezone    && [ -n "$LTIMEZONE" ]	&& DEFITEM="Wm";;
        	"Wm") 									sh_choosewm          && [ -n "$LWM" ]			&& DEFITEM="Wifi";;
        	"Wifi") 									sh_confwifi "$@"     && [ -n "$LWIFI" ]		&& DEFITEM="Extra";;
        	"Extra")									sh_confadduser "$@"  && [ -n "$LEXTRA" ]		&& DEFITEM="${cmsg_Instalar[$LC_DEFAULT]}";;
   		"${cmsg_Instalar[$LC_DEFAULT]}")	sh_install;;
   		"Services")								void-services "$LC_DEFAULT";;
        	"${cmsg_Sair[$LC_DEFAULT]}")		die "${cmsg_InstalacaoAbortada[$LC_DEFAULT]}...";;
	      *) ${DIALOG} --erase-on-exit 											\
					--title		"$ccabec" 											\
					--yes-label	"${cmsg_yeslabel[$LC_DEFAULT]}"				\
					--no-label	"${cmsg_nolabel[$LC_DEFAULT]}" 				\
					--yesno		"\n${cmsg_SairSemInstalar[$LC_DEFAULT]}?"	\
					8 70 && die
		esac
	done
}

