sh_ambiente() {
	readonly cnickefi='void'
	readonly dir_install='/mnt/voidlinux'
	readonly app_conf='/tmp/void-install.conf'
	readonly url_google='https://google.com/'
	readonly url_tarball='https://github.com/voidlinux-br/void-installer/raw/master'
	declare url_mirror='http://void.chililinux.com/voidlinux'
	readonly true=1
	readonly false=0
	readonly err_fatal=$true
	readonly err_not_fatal=$false
	readonly shell='/bin/sh'
	readonly BOOTLOG="/tmp/void-install-$(sh_diahora).log"
	readonly LOGGER='/dev/tty8'
	: "${ccabec="$APP v${_VERSION_}"}"
	: "${DIALOG=${DIALOG:-"dialog"}}"

   # flag languages
	: "${PT_BR=0}"
	: "${EN_US=1}"
	: "${DE_DE=2}"
	: "${FR_FR=3}"
	: "${LC_DEFAULT=$(sh_getlocale)}"

	# flag dialog exit status codes
	: "${D_OK=0}"
	: "${D_CANCEL=1}"
	: "${D_HELP=2}"
	: "${D_EXTRA=3}"x
	: "${D_ITEM_HELP=4}"
	: "${D_ESC=255}"

	# flag dialog menu
	: "${LDISCO=}"
	: "${LFS=}"
	: "${LGRUB=}"
	: "${LTECLADO=}"
	: "${LWM=}"
	: "${LWIFI=}"
	: "${LMIRROR=}"
	: "${LEXTRA=}"
	: "${LTIMEZONE=}"

	# dialog colors
	: "${BLACK="\Z0"}"
	: "${GREEN="\Z2"}"
	: "${MAGENTA="\Z5"}"
	: "${REVERSE="\Zr"}"
	: "${UNDERLINE="\Zu"}"
	YELLOW="\Z3"
	WHITE="\Z7"
	BLUE="\Z4"
	CYAN="\Z6"
	RED="\Z1"
	BOLD="\Zb"
	RESET="\Zn"
	: echo "$err_fatal"
	: echo "$LAUTO"
	: echo "$url_google"

	if [ -z "${COLUMNS}" ]; then
   	COLUMNS=$(stty size)
	   COLUMNS=${COLUMNS##* }
	fi
	if [ "${COLUMNS}" = "0" ]; then
   	COLUMNS=80
	fi
	COL=$((COLUMNS - 8))
	SET_COL="\\033[${COL}G" # at the $COL char
	CURS_ZERO="\\033[0G"
}

