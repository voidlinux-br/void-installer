		sh_update_sshd
		sh_update_timezone
		sh_update_locale
		sh_chroot_job "${cmsg_Configurando[$LC_DEFAULT]} locales ${cmsg_Em[$LC_DEFAULT]} $_PART_ROOT:$dir_install" "xbps-reconfigure -f glibc-locales"
		sh_mkfstab
		sh_set_keymap
