sh_checkinstall() {
	if [ -z "$LDISCO" ]; then
		alerta "${cmsg_Disco[$LC_DEFAULT]}" "${cmsg_NotConfDisco[$LC_DEFAULT]}"
		DEFITEM="${cmsg_Disco[$LC_DEFAULT]}"
		return 1
	elif [ -z "$LFS" ]; then
		alerta "FILESYSTEM" "${cmsg_NotConfFileSystem[$LC_DEFAULT]}"
		DEFITEM="FileSystem"
		return 1
	elif [ -z "$LGRUB" ]; then
		alerta "BOOTLOADER" "${cmsg_NotConfBootLoader[$LC_DEFAULT]}"
		DEFITEM="BootLoader"
		return 1
	elif [ -z "$LTECLADO" ]; then
		alerta "${cmsg_Teclado[$LC_DEFAULT]}" "${cmsg_NotConfTeclado[$LC_DEFAULT]}"
		DEFITEM="${cmsg_Teclado[$LC_DEFAULT]}"
		return 1
	elif [ -z "$LTIMEZONE" ]; then
		alerta "TIMEZONE" "${cmsg_NotConfTimezone[$LC_DEFAULT]}"
		DEFITEM="Timezone"
		return 1
	elif [ -z "$LWM" ]; then
		alerta "WM" "${cmsg_NotConfWm[$LC_DEFAULT]}"
		DEFITEM="Wm"
		return 1
	elif [ -z "$LWIFI" ]; then
		alerta "WIFI" "${cmsg_NotConfWifi[$LC_DEFAULT]}"
		DEFITEM="Wifi"
		return 1
	elif [ -z "$LEXTRA" ]; then
		alerta "EXTRA" "${cmsg_NotConfExtra[$LC_DEFAULT]}"
		DEFITEM="Extra"
		return 1
	fi

	if	[[ -z $(command -v "mkfs.$mkfs") ]]; then
		result="\n${RED}${cmsg_ERRO[$LC_DEFAULT]}${RESET}: ${cmsg_CommandNotFound[$LC_DEFAULT]} ${BOLD}${CYAN}'mkfs.$mkfs'${RESET}"
		result+="\n--------------${cmsg_ImpossivelContinuar[$LC_DEFAULT]}-------------"
		result+="\n${cmsg_ImpossivelContinuar1[$LC_DEFAULT]}"
		result+="\n${cmsg_ImpossivelContinuar2[$LC_DEFAULT]} \$PATH"
		result+="\n-----------------------------------------------"
		display_result "$result" "${cmsg_CommandNotFound[$LC_DEFAULT]}"
		die "${cmsg_ERRO[$LC_DEFAULT]}: ${cmsg_InstalacaoAbortada[$LC_DEFAULT]}... ${cmsg_CommandNotFound[$LC_DEFAULT]} ${bold}${cyan}'mkfs.$mkfs'${reset}"
	fi

	display_config
	if conf "${cmsg_ConfSalva[LC_DEFAULT]}" "$SETUP " 													\
				"\nAcompanhe a evolução da instalação: ${BLUE}sudo tail -f $BOOTLOG${RESET}"	\
				"\ne/ou pelo terminal tty8           : ${BLUE}(ctrl+alt+f8)${RESET}"				\
				"\n\n${BOLD}${WHITE}${cmsg_descInstalar[$LC_DEFAULT]}?"; then
		return 0
	fi
	return 1
}

