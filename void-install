sh_getlocale() {
	local lc

	LC_DEFAULT="${Aidioma[pt_BR]}"
	LOCALE="pt_BR"
	if lc=$(grep _ <(locale -a) | head -1 | cut -c1-5); then
		LOCALE="$lc"
		LC_DEFAULT="${Aidioma[$lc]}"
	fi
}

sh_mknodtty() {
	if [[ -c "$LOGGER" ]]; then
		return 0
	fi
	mknod -m 0620 /dev/tty8 c 4 8
	chown --reference=/dev/tty0 /dev/tty8
}

