				sh_usage
				exit $(($# ? 0 : 1))
				;;
			-v | -V | --version)
				sh_version
				exit $(($# ? 0 : 1))
				;;
			-n | --nocolor)
				sh_unsetvarcolors
				;;
			-q | --quiet)
				quiet=1
				;;
			-g | --grafico)
				grafico=1
				;;
			-i | -I | --install)
				LINSTALL=1
				appexec+=('sh_menu')
				;;
			-c | -C | --chroot)
				LCHROOT=1
				appexec+=('sh_dryrun')
				;;
			*) die "operação não suportada: $1 (use -h for help)" ;;
		esac
		shift
	done
}

